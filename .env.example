# ─── Mode base de données ──────────────────────────────────────────────────────
# sqlite  → développement local (défaut, aucune autre var DB_ requise)
# mysql   → production
DB_DRIVER=sqlite

# ─── MySQL (production) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_mysql_database

# ─── Sessions ─────────────────────────────────────────────────────────────────
# En prod (HTTP/HTTPS sans préfixe spécial) : naturo_sid
# En preview : laisser vide (la valeur par défaut __Host-naturo_session sera utilisée)
COOKIE_NAME=naturo_sid
# Chaîne aléatoire longue (min 32 chars) — générer avec : openssl rand -hex 32
SESSION_SECRET=

# ─── Mailjet SMTP ─────────────────────────────────────────────────────────────
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Naturo Pro

# ─── Google Calendar OAuth (optionnel) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.example.com/api/auth/google/callback

# ─── Assistant IA (Mistral) ───────────────────────────────────────────────────
# Clé API Mistral (console.mistral.ai). Sans elle, l'assistant répond 503 proprement.
MISTRAL_API_KEY=

# ─── URL publique (liens dans les emails) ────────────────────────────────────
PUBLIC_URL=http://localhost:3000

# ─── Node / Express ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
